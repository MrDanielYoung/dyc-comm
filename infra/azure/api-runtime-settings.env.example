APP_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/dyc_comm
MICROSOFT_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_ENTRA_CLIENT_SECRET=replace-me
MICROSOFT_ENTRA_REDIRECT_URI=https://api.comm.danielyoung.io/auth/microsoft/callback
WEB_APP_URL=https://comm.danielyoung.io
API_BASE_URL=https://api.comm.danielyoung.io
ALLOWED_ORIGINS=https://comm.danielyoung.io
KEY_VAULT_REFS_ENABLED=true
# OAuth callback allow-list. Comma-separated. ALLOWED_MICROSOFT_TENANT_IDS
# in production is built by the Configure API Runtime workflow as the
# Decoding Options tenant id (99c0...) plus the DHW and BW tenant ids
# fetched from Key Vault secrets `dhw-tid` and `bw-tid`. ALLOWED_ACCOUNT_EMAILS
# is sourced from Key Vault secret `allowed-account-emails` and is required
# alongside the tenant allow-list because a tenant such as DHW or BW
# contains far more users than the people authorized to use this app.
ALLOWED_MICROSOFT_TENANT_IDS=99c0f350-71bd-47f9-ab6a-cf10bc76533a,<dhw-tenant-id>,<bw-tenant-id>
ALLOWED_ACCOUNT_EMAILS=daniel@danielyoung.io,daniel.young@digitalhealthworks.com,<your-bw-email>

# Optional Azure OpenAI classifier. Configure these once a US-region
# Azure OpenAI resource + model deployment exists.
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_API_KEY=<key-vault-secret-value>
