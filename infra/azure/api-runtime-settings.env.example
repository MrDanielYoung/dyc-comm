APP_ENV=production
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/dyc_comm
MICROSOFT_ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
MICROSOFT_ENTRA_CLIENT_SECRET=replace-me
MICROSOFT_ENTRA_REDIRECT_URI=https://api.comm.danielyoung.io/auth/microsoft/callback
WEB_APP_URL=https://comm.danielyoung.io
API_BASE_URL=https://api.comm.danielyoung.io
ALLOWED_ORIGINS=https://comm.danielyoung.io
KEY_VAULT_REFS_ENABLED=true
# OAuth callback allow-list. Comma-separated. When ALLOWED_MICROSOFT_TENANT_IDS
# is unset the API falls back to MICROSOFT_ENTRA_TENANT_ID only — set this
# explicitly to permit external tenants (DHW shown for illustration). When
# ALLOWED_ACCOUNT_EMAILS is set, only those addresses can complete sign-in;
# leave empty to allow any user from an allow-listed tenant.
ALLOWED_MICROSOFT_TENANT_IDS=99c0f350-71bd-47f9-ab6a-cf10bc76533a,3dd54b52-c31e-442e-8705-a56b839e59a7
ALLOWED_ACCOUNT_EMAILS=daniel@danielyoung.io,daniel.young@digitalhealthworks.com
