# Copy to apps/api/.env for local development. Never commit a populated .env.
APP_ENV=local

# PostgreSQL connection string for local dev.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dyc_comm

# Microsoft Entra (Azure AD) OAuth — register an app for local dev.
MICROSOFT_ENTRA_CLIENT_ID=
MICROSOFT_ENTRA_TENANT_ID=
MICROSOFT_ENTRA_CLIENT_SECRET=
MICROSOFT_ENTRA_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# Public URLs the API redirects to and trusts for CORS.
WEB_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
# Comma-separated. Defaults to WEB_APP_URL when empty.
ALLOWED_ORIGINS=

# Set to true in environments where secrets resolve via Azure Key Vault refs.
KEY_VAULT_REFS_ENABLED=false

# OAuth callback allow-list. Empty values fall back to MICROSOFT_ENTRA_TENANT_ID
# (the home tenant) and an unrestricted email allow-list. Set explicitly to
# admit external tenants and accounts. Example values for prod:
#   ALLOWED_MICROSOFT_TENANT_IDS=99c0f350-71bd-47f9-ab6a-cf10bc76533a,3dd54b52-c31e-442e-8705-a56b839e59a7
#   ALLOWED_ACCOUNT_EMAILS=daniel@danielyoung.io,daniel.young@digitalhealthworks.com
ALLOWED_MICROSOFT_TENANT_IDS=
ALLOWED_ACCOUNT_EMAILS=

# Optional Azure OpenAI classifier. Use a US-region Azure OpenAI resource
# and a chat model deployment such as gpt-5-mini when available.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_API_KEY=
