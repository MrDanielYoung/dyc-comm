# Copy to apps/api/.env for local development. Never commit a populated .env.
APP_ENV=local

# PostgreSQL connection string for local dev.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dyc_comm

# Microsoft Entra (Azure AD) OAuth — register an app for local dev.
MICROSOFT_ENTRA_CLIENT_ID=
MICROSOFT_ENTRA_TENANT_ID=
MICROSOFT_ENTRA_CLIENT_SECRET=
MICROSOFT_ENTRA_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback

# Set to true in environments where secrets resolve via Azure Key Vault refs.
KEY_VAULT_REFS_ENABLED=false
